## Copy to `.env` and fill in real secrets locally.
## Never commit real keys (Stripe/Telegram/etc).

# Core
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
BASE_URL=http://localhost:8000

# Security (production must be strong / non-default)
ADMIN_API_KEY=YOUR_ADMIN_API_KEY
# 64 hex chars (32 bytes). Generate with: `python -c "import secrets; print(secrets.token_hex(32))"`
CREDENTIAL_ENCRYPTION_KEY=YOUR_64_HEX_CREDENTIAL_ENCRYPTION_KEY

# Stripe
# Use `sk_test_...` for testing, `sk_live_...` for production.
STRIPE_SECRET_KEY=sk_placeholder
STRIPE_PUBLISHABLE_KEY=pk_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_ENV=live
STRIPE_STATUS=PRODUCTION

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
# Telegram Payments provider token from @BotFather (NOT your Stripe API key)
STRIPE_PROVIDER_TOKEN=YOUR_STRIPE_PROVIDER_TOKEN

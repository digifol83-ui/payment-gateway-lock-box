## Copy to `.env` and fill in real secrets locally.
## Never commit real keys (Stripe/Telegram/etc).

# Core
DEBUG=false
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=json
BASE_URL=http://localhost:8000

# Security (production must be strong / non-default)
ADMIN_API_KEY=YOUR_ADMIN_API_KEY
# 64 hex chars (32 bytes). Generate with: `python -c "import secrets; print(secrets.token_hex(32))"`
CREDENTIAL_ENCRYPTION_KEY=YOUR_64_HEX_CREDENTIAL_ENCRYPTION_KEY

# Transak
TRANSAK_API_KEY=
TRANSAK_SECRET=
TRANSAK_ACCESS_TOKEN=
TRANSAK_ENV=PRODUCTION
TRANSAK_EMAIL=
TRANSAK_BRAND_NAME=
TRANSAK_COMPANY_NAME=
TRANSAK_LOGO_URL=
TRANSAK_WEBSITE=
TRANSAK_THEME=dark
TRANSAK_SEND_CUSTOMER_EMAILS=false

# MoonPay
MOONPAY_API_KEY=
MOONPAY_SECRET=
MOONPAY_WEBHOOK_SECRET=
MOONPAY_ENV=sandbox

# Telegram (optional)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID
TELEGRAM_WEBHOOK_SECRET=YOUR_TELEGRAM_WEBHOOK_SECRET
# Telegram Payments provider token from @BotFather.
TELEGRAM_PAYMENT_PROVIDER_TOKEN=YOUR_TELEGRAM_PROVIDER_TOKEN
